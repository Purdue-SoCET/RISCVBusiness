#
# Mnemonic Maps
#
mmap new  -reuse -name {Boolean as Logic} -radix %b -contents {{%c=FALSE -edgepriority 1 -shape low}
{%c=TRUE -edgepriority 1 -shape high}}
mmap new  -reuse -name {Example Map} -radix %x -contents {{%b=11???? -bgcolor orange -label REG:%x -linecolor yellow -shape bus}
{%x=1F -bgcolor red -label ERROR -linecolor white -shape EVENT}
{%x=2C -bgcolor red -label ERROR -linecolor white -shape EVENT}
{%x=* -label %x -linecolor gray -shape bus}}

#
# Design Browser windows
#
if {[catch {window new WatchList -name "Design Browser 1" -geometry 730x500+261+33}] != ""} {
    window geometry "Design Browser 1" 730x500+261+33
}
window target "Design Browser 1" on
browser using {Design Browser 1}
browser set \
    -signalsort name
browser timecontrol set -lock 0

#
# Waveform windows
#
if {[catch {window new WaveWindow -name "Waveform 2" -geometry 1920x887+0+49}] != ""} {
    window geometry "Waveform 2" 1920x887+0+49
}
window target "Waveform 2" on
waveform using {Waveform 2}
waveform sidebar select designbrowser
waveform set \
    -primarycursor TimeA \
    -signalnames name \
    -signalwidth 175 \
    -units ps \
    -valuewidth 204
waveform baseline set -time 0


set groupId0 [waveform add -groups sys]


set groupId0 [waveform add -groups {{gold bus}}]
set gpGlist0 [waveform hierarchy contents $groupId0]
set gpID0 [lindex $gpGlist0 0]
foreach {name attrs} [subst  {
    {simulator::[format {tb_caches.gold_ram.v_lat_ram.memory}]} {-height 95 -trace assocarray}
    {simulator::[format {tb_caches.gold_bus_if.addr[31:0]}]} {}
    {simulator::[format {tb_caches.gold_bus_if.busy}]} {}
    {simulator::[format {tb_caches.gold_bus_if.byte_en[3:0]}]} {-radix %b}
    {simulator::[format {tb_caches.gold_bus_if.error}]} {}
    {simulator::[format {tb_caches.gold_bus_if.rdata[31:0]}]} {}
    {simulator::[format {tb_caches.gold_bus_if.ren}]} {}
    {simulator::[format {tb_caches.gold_bus_if.wdata[31:0]}]} {}
    {simulator::[format {tb_caches.gold_bus_if.wen}]} {}
}] childcmds {
    {}
    {}
    {}
    {}
    {}
    {}
    {}
    {}
    {}
} {
    set expected [ join [waveform signals -format fullpath $gpID0] ]
    if {[string equal $name $expected] || $name == "cdivider"} {
        if {$attrs != ""} {
            eval waveform format $gpID0 $attrs
        }
        if { $childcmds != ""} {
            eval $childcmds
        }
    }
    set gpGlist0 [lrange $gpGlist0 1 end]
    set gpID0 [lindex $gpGlist0 0]
}


set groupId0 [waveform add -groups busses]

set groupId1 [waveform find -name {CPU bus}]


set groupId1 [waveform find -name {RAM bus}]
waveform hierarchy collapse $groupId1


set groupId1 [waveform find -name {CACHE <-> RAM bus}]
waveform hierarchy collapse $groupId1


set groupId1 [waveform find -name {TB -> RAM bus}]
waveform hierarchy collapse $groupId1



set groupId0 [waveform add -groups RAM]

set groupId1 [waveform find -name {RAM Signals}]
waveform hierarchy collapse $groupId1

set gpGlist0 [waveform hierarchy contents $groupId0]
set gpID0 [lindex $gpGlist0 0]
foreach {name attrs} [subst  {
    {simulator::[format {tb_caches.DUT_ram.v_lat_ram.memory}]} {-height 95 -trace assocarray}
    groupId55 {}
}] childcmds {
