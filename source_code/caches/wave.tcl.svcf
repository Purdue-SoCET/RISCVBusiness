set groupId0 [waveform add -groups CACHE]

set groupId1 [waveform find -name {CACHE SIGNALS}]

set groupId2 [waveform find -name {CACHE FLUSH}]
waveform hierarchy collapse $groupId2


set groupId2 [waveform find -name {CACHE CLEAR}]
waveform hierarchy collapse $groupId2




