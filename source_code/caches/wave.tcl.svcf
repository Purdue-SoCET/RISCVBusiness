            eval waveform format $gpID0 $attrs
        }
        if { $childcmds != ""} {
            eval $childcmds
        }
    }
    set gpGlist0 [lrange $gpGlist0 1 end]
    set gpID0 [lindex $gpGlist0 0]
}


set groupId0 [waveform add -groups {{CACHE MEM}}]

set groupId1 [waveform find -name {CACHE MEM SIGNALS}]

set gpGlist0 [waveform hierarchy contents $groupId0]
set gpID0 [lindex $gpGlist0 0]
foreach {name attrs} [subst  {
    {simulator::[format {tb_caches.DUT.cache_mem.v_lat_ram.memory}]} {-height 124 -trace assocarray}
    groupId65 {}
